GROQ_API_KEY=paste_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Optional second cloud provider. Set JCT_LLM_PROVIDER=gemini to prefer this over
# Groq for the table-primary/escalation slot in translate_service.py — both
# use the same interface and share the same translation cache, so either can
# be configured alone or both together (cloud_configured is true if either is set).
GEMINI_API_KEY=paste_here
GEMINI_MODEL=gemini-flash-latest
GEMINI_MAX_REQUESTS_PER_MINUTE=15
JCT_LLM_PROVIDER=groq

# Optional. Supabase: Project Settings -> Database -> Connection string -> the
# "Transaction pooler" or "Session pooler" tab (NOT "Direct connection" -- that
# one is IPv6-only and won't resolve on most networks).
# Unset = document_store/job_service fall back to in-memory (Phase 1 behavior).
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
# Optional. Unset = translation caching is skipped (always translate).
REDIS_URL=redis://default:password@your-redis-host:6379

# Optional. Slack incoming-webhook URL for developer error alerts (see
# core/notifications.py). Unset = alerts are skipped silently.
SLACK_WEBHOOK_URL=paste_here

# Optional. When true, every translation cache lookup misses (writes still
# happen, so the cache stays warm for everyone else) — use while iterating on
# prompts so a stale cache hit can't mask your changes. Per-request
# equivalent: POST /upload?force_refresh=true.
DEV_MODE=false

# Optional. When true, /upload rejects scanned PDFs/raw images before they
# can trigger the OCR cascade (YomiToku + manga-ocr + torch), which needs
# far more RAM than a 512MB instance has. Digital PDFs are unaffected.
# Set true on a memory-constrained deployment (e.g. Render free tier).
LOW_MEMORY_MODE=false

APP_ENV=development
CORS_ORIGINS=https://jctai.netlify.app,http://localhost:5173
MAX_UPLOAD_MB=25
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/output
TEMP_DIR=./data/tmp
LOG_LEVEL=INFO
